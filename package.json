{
  "name": "@stonyx/events",
  "keywords": [
    "stonyx-module"
  ],
  "version": "0.1.1-beta.36",
  "description": "Lightweight pub/sub event system for the Stonyx framework",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "pnpm build && pnpm build:test && qunit 'dist-test/test/**/*.js'",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abofs/stonyx-events.git"
  },
  "author": "Stone Costa",
  "license": "Apache-2.0",
  "contributors": [
    "Stone Costa <stone.costa@synamicd.com>"
  ],
  "bugs": {
    "url": "https://github.com/abofs/stonyx-events/issues"
  },
  "homepage": "https://github.com/abofs/stonyx-events#readme",
  "devDependencies": {
    "@stonyx/utils": "0.2.3-beta.19",
    "@types/node": "^25.5.2",
    "@types/qunit": "^2.19.13",
    "qunit": "^2.24.1",
    "sinon": "^21.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {}
}
